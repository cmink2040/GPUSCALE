# =============================================================================
# GPUSCALE Benchmark Container — llama.cpp + Meta native inference
# No vLLM — lean image (~2-3 GB compressed)
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: Build llama.cpp from source with CUDA
# ---------------------------------------------------------------------------
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04 AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake git build-essential libcurl4-openssl-dev \
    && rm -rf /var/lib/apt/lists/*

ARG LLAMA_CPP_TAG=b5200
RUN git clone --depth 1 --branch ${LLAMA_CPP_TAG} \
    https://github.com/ggerganov/llama.cpp /llama.cpp

WORKDIR /llama.cpp
RUN ln -s /usr/local/cuda/lib64/stubs/libcuda.so /usr/lib/x86_64-linux-gnu/libcuda.so.1 \
    && cmake -B build \
    -DGGML_CUDA=ON \
    -DCMAKE_CUDA_ARCHITECTURES="60;70;75;80;86;89;90" \
    && cmake --build build --config Release -j$(nproc)

# ---------------------------------------------------------------------------
# Stage 2: Runtime image (no vLLM, no PyTorch bloat)
# ---------------------------------------------------------------------------
FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    jq curl libcurl4 \
    && rm -rf /var/lib/apt/lists/*

# uv for fast Python installs
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# llama.cpp binaries from builder
COPY --from=builder /llama.cpp/build/bin/llama-cli /usr/local/bin/llama-cli
COPY --from=builder /llama.cpp/build/bin/llama-server /usr/local/bin/llama-server

# Python deps — llama-models for Meta native .pth, boto3/HF for model pulling
COPY requirements.llamacpp.txt /tmp/requirements.txt
RUN uv pip install --system --no-cache -r /tmp/requirements.txt

# Application code
WORKDIR /app
COPY entrypoint.sh /app/entrypoint.sh
COPY scripts/ /app/scripts/
COPY workloads/ /app/workloads/

RUN chmod +x /app/entrypoint.sh /app/scripts/*.sh
RUN mkdir -p /models /results

ENTRYPOINT ["/app/entrypoint.sh"]
