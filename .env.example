# Vast.ai
VAST_API_KEY=

# RunPod
RUNPOD_API_KEY=

# Meta Llama (signed URL from https://llama.meta.com/, expires in 24h)
META_LLAMA_URL=

# Wasabi S3 (model storage)
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=
WASABI_REGION=us-east-1                   # Must match your bucket's region
WASABI_ENDPOINT=https://s3.wasabisys.com  # Or region-specific: https://s3.<region>.wasabisys.com

# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY= # Public read-only key (results-disp)
SUPABASE_SECRET_KEY=       # Secret key (dbops write access)

# Database (Supabase Postgres direct connection — used by dbops)
DATABASE_URL=             # e.g. postgresql://postgres.<ref>:<password>@<host>:5432/postgres
