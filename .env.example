# Vast.ai
VAST_API_KEY=

# RunPod
RUNPOD_API_KEY=

# eBay Browse API (for `dbops gpu-price collect` hardware prices).
# Register an app at https://developer.ebay.com and use the PRODUCTION keyset.
# The collector uses the client credentials grant, so no user consent flow —
# just paste the App ID (client_id) and Cert ID (client_secret).
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# HuggingFace (for gated models like Llama 3.1)
HF_TOKEN=

# Meta Llama (signed URL from https://llama.meta.com/, expires in 24h)
META_LLAMA_URL=

# Wasabi S3 (model storage)
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=
WASABI_REGION=us-east-1                   # Must match your bucket's region
WASABI_ENDPOINT=https://s3.wasabisys.com  # Or region-specific: https://s3.<region>.wasabisys.com

# Supabase
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY= # Public read-only key (results-disp)
SUPABASE_SECRET_KEY=       # Secret key (dbops write access)

# Database (Supabase Postgres direct connection — used by dbops)
DATABASE_URL=             # e.g. postgresql://postgres.<ref>:<password>@<host>:5432/postgres
